# Frontend (Vite build-time variables)
VITE_HISTORY_API_URL=           # Backend API URL. Empty = relative (nginx proxy). Default: http://localhost:8080
VITE_DONATEX_CLIENT_ID=         # Donatex OAuth client ID (optional)

# Docker Compose
POSTGRES_DB=vertuta
POSTGRES_USER=vertuta
POSTGRES_PASSWORD=vertuta       # Change in production!

# Server (.NET)
# AllowedOrigins__0=http://localhost:3000   # CORS origins (array via __ notation)
# ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=vertuta;Username=vertuta;Password=vertuta
